GITHUB_TOKEN=
GITHUB_ORG=OKsystem
GITHUB_PROJECT_NUMBER=
GITHUB_PROJECT_NUMBERS=
GITHUB_INCLUDE_ALL_PROJECTS=false
GITHUB_INCLUDE_CLOSED_PROJECTS=false
GITHUB_PROJECT_OWNER_TYPE=org
GITHUB_REPOSITORY_ALLOWLIST=oklab-chatbot
GITHUB_REPOSITORY_DENYLIST=
GITHUB_INCLUDE_ALL_REPOSITORIES=false
TARGET_ASSIGNEES=FIRST_ACCOUNT_HERE,SECOND_ACCOUNT_HERE

# Use the EXACT field names from your Project V2 board (case-insensitive match).
REQUIRED_PROJECT_FIELDS=Priority,Difficulty,Iteration (sprint),Estimate
# Add Status and/or Start date if your workflow requires them:
# REQUIRED_PROJECT_FIELDS=Priority,Difficulty,Iteration (sprint),Estimate,Status,Start date
OPTIONAL_PROJECT_FIELDS=Note,Start date,End date

REQUIRE_ASSIGNEE=true
REQUIRE_TARGET_ASSIGNEE=true
# Issues must be on the project board; PRs are exempt unless the second flag is on.
REQUIRE_PROJECT_ITEM=true
REQUIRE_PROJECT_ITEM_PULL_REQUESTS=false
REQUIRE_DEVELOPMENT_LINK=true
REQUIRE_LINKED_PR_OR_BRANCH=true

INCLUDE_CLOSED_ISSUES=false
INCLUDE_CLOSED_PULL_REQUESTS=false
INCLUDE_PULL_REQUESTS=true
INCLUDE_ISSUES=true
GITHUB_UPDATED_FROM=
GITHUB_UPDATED_TO=

AUTO_APPLY=false
AUTO_APPLY_MIN_CONFIDENCE=0.85

LLM_ENABLED=true
LLM_PROVIDER=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_NAME=
LLM_API_VERSION=
LLM_TIMEOUT_SECONDS=30

# Existing Azure-style aliases are also accepted:
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=
# AZURE_LLM_MODEL_NAME=
